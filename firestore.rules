rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user owns their subtree: decks, cards chunks, progress.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Global video cache: server-only (Cloud Functions via Admin SDK bypass
    // rules). Clients get transcripts through the `ingest` callable.
    match /videos/{videoId}/{document=**} {
      allow read, write: if false;
    }
  }
}
